{
  "manifest_version": 3,
  "name": "Pagex",
  "version": "0.2.0",
  "description": "Extract page content into AI-ready JSON, capture full-page screenshots, and export cookies — all offline.",
  "permissions": [
    "activeTab",
    "cookies",
    "scripting",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "assets/icons/pagex-16.png",
    "32": "assets/icons/pagex-32.png",
    "48": "assets/icons/pagex-48.png",
    "128": "assets/icons/pagex-128.png"
  },
  "action": {
    "default_title": "Pagex",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/pagex-16.png",
      "32": "assets/icons/pagex-32.png"
    }
  },
  "minimum_chrome_version": "116"
}
